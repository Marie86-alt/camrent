rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return signedIn() && request.auth.uid == ownerId;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && userRole() == 'admin';
    }

    function validBookingCreate() {
      return request.resource.data.keys().hasOnly([
          'carId',
          'carBrand',
          'carModel',
          'ownerId',
          'clientId',
          'startDate',
          'endDate',
          'totalDays',
          'totalPrice',
          'paymentMethod',
          'paymentStatus',
          'driverLicense',
          'status',
          'withDriver',
          'driverId',
          'driverName',
          'driverPhotoUrl',
          'driverPricePerDay',
          'createdAt'
        ])
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.paymentStatus == 'unpaid'
        && request.resource.data.paymentMethod in ['MTN MoMo', 'Orange Money', 'Carte bancaire']
        && request.resource.data.totalDays is int
        && request.resource.data.totalDays >= 1
        && request.resource.data.totalPrice is number
        && request.resource.data.totalPrice > 0
        && validBookingDriverFields()
        && validDriverLicense(request.resource.data.driverLicense);
    }

    function validBookingDriverFields() {
      return !request.resource.data.keys().hasAny(['withDriver'])
        || request.resource.data.withDriver == false
        || (
          request.resource.data.withDriver == true
          && request.resource.data.driverId is string
          && request.resource.data.driverId.size() > 0
          && request.resource.data.driverName is string
          && request.resource.data.driverName.size() > 0
          && request.resource.data.driverPricePerDay is number
          && request.resource.data.driverPricePerDay >= 0
        );
    }

    function validDriverLicense(license) {
      return license is map
        && license.keys().hasOnly([
          'fullName',
          'licenseNumber',
          'issuingCountry',
          'issueDate',
          'expiryDate',
          'categories'
        ])
        && license.fullName is string
        && license.fullName.size() >= 3
        && license.licenseNumber is string
        && license.licenseNumber.size() >= 5
        && license.issuingCountry is string
        && license.issuingCountry.size() >= 2
        && license.issueDate is string
        && license.issueDate.size() == 10
        && license.expiryDate is string
        && license.expiryDate.size() == 10
        && license.categories is string
        && license.categories.size() >= 1;
    }

    function validBookingUpdate() {
      let changed = request.resource.data.diff(resource.data).changedKeys();

      return signedIn()
        && (
          (
            request.auth.uid == resource.data.ownerId
            && changed.hasOnly(['status'])
            && request.resource.data.status in ['confirmed', 'cancelled', 'completed']
          )
          || (
            request.auth.uid == resource.data.clientId
            && changed.hasOnly(['status'])
            && request.resource.data.status == 'cancelled'
          )
          || (
            isAdmin()
            && changed.hasOnly(['status', 'disputeStatus', 'refundStatus', 'depositStatus'])
            && request.resource.data.status in ['pending', 'confirmed', 'cancelled', 'completed']
          )
        );
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || userRole() == 'owner' || isAdmin());
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if false;
    }

    match /cars/{carId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && userRole() == 'owner';
      allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if signedIn()
        && (
          resource.data.clientId == request.auth.uid
          || resource.data.ownerId == request.auth.uid
          || resource.data.driverId == request.auth.uid
          || isAdmin()
        );
      allow create: if signedIn() && validBookingCreate();
      allow update: if validBookingUpdate();
      allow delete: if false;
    }

    match /payments/{paymentId} {
      allow read, update: if isAdmin();
      allow create, delete: if false;
    }

    match /adminSettings/{settingId} {
      allow read, write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /promoBanners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adminNotifications/{notificationId} {
      allow read, write: if isAdmin();
    }

    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
