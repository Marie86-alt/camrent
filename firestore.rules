rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return signedIn() && request.auth.uid == ownerId;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && userRole() == 'admin';
    }

    function isIndependentDriverCreate(userId) {
      return signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'driver'
        && request.resource.data.status == 'pending_validation'
        && request.resource.data.kycStatus == 'pending'
        && request.resource.data.driverProfile.isIndependent == true
        && !request.resource.data.keys().hasAny(['ownerId', 'ratingAverage', 'missionsCount', 'adminRole']);
    }

    function validSelfUserCreate(userId) {
      return signedIn()
        && request.auth.uid == userId
        && (
          (
            request.resource.data.role in ['client', 'owner']
            && !request.resource.data.keys().hasAny([
              'adminLastActionReason',
              'adminRole',
              'kycStatus',
              'missionsCount',
              'ownerId',
              'ratingAverage',
              'status'
            ])
          )
          || isIndependentDriverCreate(userId)
        );
    }

    function validSelfUserUpdate(userId) {
      let changed = request.resource.data.diff(resource.data).changedKeys();

      return signedIn()
        && request.auth.uid == userId
        && !changed.hasAny([
          'adminLastActionReason',
          'adminRole',
          'kycStatus',
          'missionsCount',
          'ownerId',
          'ratingAverage',
          'role',
          'status'
        ]);
    }

    function validBookingUpdate() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      let affected = request.resource.data.diff(resource.data).affectedKeys();

      return signedIn()
        && (
          (
            request.auth.uid == resource.data.ownerId
            && changed.hasOnly(['status'])
            && request.resource.data.status in ['confirmed', 'completed']
          )
          || (
            request.auth.uid == resource.data.clientId
            && resource.data.status == 'completed'
            && changed.hasOnly(['reviewSubmitted', 'driverReviewSubmitted'])
            && (!changed.hasAny(['reviewSubmitted']) || request.resource.data.reviewSubmitted == true)
            && (!changed.hasAny(['driverReviewSubmitted']) || request.resource.data.driverReviewSubmitted == true)
          )
          || (
            request.auth.uid == resource.data.clientId
            && affected.hasOnly(['contractStatus', 'clientSignatureUrl', 'contractSignedAt', 'contractRef'])
            && request.resource.data.contractStatus == 'client_signed'
            && request.resource.data.clientSignatureUrl is string
            && request.resource.data.contractRef is string
          )
          || (
            isAdmin()
            && changed.hasOnly(['status', 'disputeStatus', 'refundStatus', 'depositStatus'])
            && request.resource.data.status in ['pending', 'confirmed', 'cancelled', 'completed']
          )
        );
    }

    function validOwnerCarCreate() {
      return signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && userRole() == 'owner'
        && request.resource.data.adminStatus == 'pending_review'
        && request.resource.data.documentsVerified == false
        && request.resource.data.isAvailable == false;
    }

    function validOwnerCarUpdate() {
      let changed = request.resource.data.diff(resource.data).changedKeys();

      return isOwner(resource.data.ownerId)
        && request.resource.data.ownerId == resource.data.ownerId
        && (
          (
            changed.hasOnly(['isAvailable'])
            && resource.data.adminStatus == 'approved'
            && request.resource.data.adminStatus == resource.data.adminStatus
            && request.resource.data.documentsVerified == resource.data.documentsVerified
          )
          || (
            changed.hasOnly([
              'adminStatus',
              'allowIndependentDrivers',
              'brand',
              'city',
              'description',
              'documentsVerified',
              'fuelType',
              'imageUrl',
              'imageUrls',
              'isAvailable',
              'model',
              'pricePerDay',
              'seats',
              'technicalSheet',
              'transmission',
              'year'
            ])
            && request.resource.data.adminStatus == 'pending_review'
            && request.resource.data.documentsVerified == false
            && request.resource.data.isAvailable == false
          )
        );
    }

    match /users/{userId} {
      allow read: if signedIn()
        && (
          request.auth.uid == userId
          || userRole() == 'owner'
          || isAdmin()
          || (
            resource.data.role == 'driver'
            && resource.data.status == 'active'
            && resource.data.kycStatus == 'approved'
            && resource.data.driverProfile.isIndependent == true
          )
        );
      allow create: if validSelfUserCreate(userId);
      allow update: if validSelfUserUpdate(userId) || isAdmin();
      allow delete: if false;
    }

    match /cars/{carId} {
      allow read: if true;
      allow create: if validOwnerCarCreate() || isAdmin();
      allow update: if validOwnerCarUpdate() || isAdmin();
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if signedIn()
        && (
          resource.data.clientId == request.auth.uid
          || resource.data.ownerId == request.auth.uid
          || resource.data.driverId == request.auth.uid
          || isAdmin()
        );
      allow create: if false;
      allow update: if validBookingUpdate();
      allow delete: if false;
    }

    match /payments/{paymentId} {
      allow read, update: if isAdmin();
      allow create, delete: if false;
    }

    match /adminSettings/{settingId} {
      allow read, write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    match /promoBanners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adminNotifications/{notificationId} {
      allow read, write: if isAdmin();
    }

    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
