EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# Public: endpoint backend/Cloud Function appele par l'app mobile.
EXPO_PUBLIC_PAYMENTS_API_URL=https://your-backend.example.com/payments/mobile-money
EXPO_PUBLIC_NOTIFICATIONS_API_URL=https://your-backend.example.com/notifications/send-admin-notification
EXPO_PUBLIC_CITY_SEARCH_API_URL=https://your-backend.example.com/cities/search
EXPO_PUBLIC_CREATE_DRIVER_API_URL=https://your-backend.example.com/drivers/create-owner-driver
EXPO_PUBLIC_SUBMIT_REVIEW_API_URL=https://your-backend.example.com/reviews/submit
EXPO_PUBLIC_AVAILABLE_DRIVERS_API_URL=https://your-backend.example.com/drivers/available

# Server only: a mettre uniquement dans ton backend, jamais dans Expo.
CAMPAY_APP_USERNAME=your-campay-app-username
CAMPAY_APP_PASSWORD=your-campay-app-password
CAMPAY_ACCESS_TOKEN=optional-existing-campay-access-token
CAMPAY_BASE_URL=https://demo.campay.net
CAMPAY_REDIRECT_URL=https://your-app-or-site.example.com/payment-success
CAMPAY_FAILURE_REDIRECT_URL=https://your-app-or-site.example.com/payment-failed
CAMPAY_WEBHOOK_URL=https://your-functions-url/campayWebhook
CAMPAY_WEBHOOK_SECRET=choose-a-random-secret
ORANGE_MONEY_CLIENT_ID=your-orange-client-id
ORANGE_MONEY_CLIENT_SECRET=your-orange-client-secret
ORANGE_MONEY_MERCHANT_KEY=your-orange-merchant-key
MTN_MOMO_SUBSCRIPTION_KEY=your-mtn-subscription-key
MTN_MOMO_API_USER=your-mtn-api-user
MTN_MOMO_API_KEY=your-mtn-api-key
MOBILE_MONEY_ENV=sandbox
